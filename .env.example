# ============================================================
# Astraly.app — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI — Anthropic (Claude Sonnet — PRO plans) ────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── AI — DeepSeek (Free/basic plans) ─────────────────────
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# ── Email — Resend ────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@astraly.app
RESEND_SUPPORT_EMAIL=support@astraly.app

# ── Payments — Lemon Squeezy ──────────────────────────────
# Get from: https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=your-api-key
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
LEMONSQUEEZY_STORE_ID=your-store-id

# Product variant IDs (set up plans in Lemon Squeezy dashboard)
LEMONSQUEEZY_MOONLIGHT_VARIANT_ID=
LEMONSQUEEZY_SOLAR_VARIANT_ID=
LEMONSQUEEZY_COSMIC_VARIANT_ID=

# ── Google (OAuth + Calendar API) ────────────────────────
# Get from: https://console.cloud.google.com → Credentials
# Enable: Google Calendar API, Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Telegram Bot ──────────────────────────────────────────
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_BOT_USERNAME=AstralyBot

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to your domain in production:
# NEXT_PUBLIC_APP_URL=https://astraly.app

# ── Cron (Vercel) ─────────────────────────────────────────
# Secret for protecting cron job endpoints
CRON_SECRET=generate-a-random-secret-here
