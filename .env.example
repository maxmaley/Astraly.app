# ============================================================
# Astraly.app — Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── AI — Anthropic (Claude Sonnet — PRO plans) ────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── AI — DeepSeek (Free/basic plans) ─────────────────────
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# ── Email — Resend ────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@astraly.app
RESEND_SUPPORT_EMAIL=support@astraly.app

# ── Payments — Paddle ────────────────────────────────────
# Get from: https://vendors.paddle.com → Developer Tools
PADDLE_API_KEY=your-api-key
PADDLE_WEBHOOK_SECRET=your-webhook-secret

# Price IDs (set up plans in Paddle dashboard)
PADDLE_MOONLIGHT_MONTHLY_PRICE_ID=
PADDLE_MOONLIGHT_YEARLY_PRICE_ID=
PADDLE_SOLAR_MONTHLY_PRICE_ID=
PADDLE_SOLAR_YEARLY_PRICE_ID=
PADDLE_COSMIC_MONTHLY_PRICE_ID=
PADDLE_COSMIC_YEARLY_PRICE_ID=

# ── Google (OAuth + Calendar API) ────────────────────────
# Get from: https://console.cloud.google.com → Credentials
# Enable: Google Calendar API, Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to your domain in production:
# NEXT_PUBLIC_APP_URL=https://astraly.app

# ── Cron (Vercel) ─────────────────────────────────────────
# Secret for protecting cron job endpoints
CRON_SECRET=generate-a-random-secret-here
